{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omena.dev/schemas/lock-v1.schema.json",
  "title": "Omena Lockfile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["lockfileVersion", "entries"],
  "properties": {
    "lockfileVersion": {
      "const": "1"
    },
    "omenaMinVersion": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sifEntry"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^blake3:[0-9a-f]{64}$"
    },
    "sifEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalUrl", "sifPath", "sifHash", "interfaceHash", "transitiveHash"],
      "properties": {
        "canonicalUrl": {
          "type": "string",
          "minLength": 1
        },
        "sifPath": {
          "type": "string",
          "minLength": 1
        },
        "sifHash": {
          "$ref": "#/$defs/digest"
        },
        "interfaceHash": {
          "$ref": "#/$defs/digest"
        },
        "transitiveHash": {
          "$ref": "#/$defs/digest"
        },
        "trustTier": {
          "$ref": "#/$defs/trustTier"
        },
        "attestationReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attestationReference"
          }
        },
        "attestationVerifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attestationVerification"
          }
        }
      }
    },
    "trustTier": {
      "enum": ["t0", "t1", "t2", "t3"]
    },
    "attestationReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "attestationVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference", "verifier", "verifiedTrustTier"],
      "allOf": [
        {
          "if": {
            "properties": {
              "verifier": {
                "const": "sigstore-verify"
              }
            },
            "required": ["verifier"]
          },
          "then": {
            "required": [
              "sigstoreVerificationPolicy",
              "certificateIssuer",
              "verifiedTlogIntegratedTime"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "(^sigstore-bundle$|\\.sigstore$)"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": [
              "sigstoreVerificationPolicy",
              "certificateIssuer",
              "verifiedTlogIntegratedTime"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "^(npm-provenance|omena-toolchain)\\."
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["attestationStatement"]
          }
        },
        {
          "if": {
            "properties": {
              "verifiedTrustTier": {
                "const": "t3"
              }
            },
            "required": ["verifiedTrustTier"]
          },
          "then": {
            "required": ["certificateIssuer", "certificateIdentity"],
            "properties": {
              "kind": {
                "type": "string",
                "pattern": "^omena-toolchain\\."
              }
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string",
          "minLength": 1
        },
        "verifier": {
          "type": "string",
          "minLength": 1
        },
        "verifiedTrustTier": {
          "$ref": "#/$defs/trustTier"
        },
        "verifiedTlogIntegratedTime": {
          "type": "integer",
          "minimum": 1
        },
        "sigstoreVerificationPolicy": {
          "$ref": "#/$defs/sigstoreVerificationPolicy"
        },
        "certificateIssuer": {
          "type": "string",
          "minLength": 1
        },
        "certificateIdentity": {
          "type": "string",
          "minLength": 1
        },
        "attestationStatement": {
          "$ref": "#/$defs/attestationStatement"
        }
      }
    },
    "sigstoreVerificationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trustedRoot",
        "transparencyLog",
        "timestamp",
        "certificateChain",
        "signedCertificateTimestamp"
      ],
      "properties": {
        "trustedRoot": {
          "type": "string",
          "minLength": 1
        },
        "transparencyLog": {
          "const": true
        },
        "timestamp": {
          "const": true
        },
        "certificateChain": {
          "const": true
        },
        "signedCertificateTimestamp": {
          "const": true
        }
      }
    },
    "attestationStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statementType",
        "predicateType",
        "sourceRepository",
        "sourceRef",
        "sourceCommit",
        "builderId",
        "buildType",
        "subjectNames",
        "subjectDigests"
      ],
      "properties": {
        "statementType": {
          "type": "string",
          "minLength": 1
        },
        "predicateType": {
          "type": "string",
          "minLength": 1
        },
        "sourceRepository": {
          "type": "string",
          "minLength": 1
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        },
        "sourceCommit": {
          "type": "string",
          "minLength": 1
        },
        "builderId": {
          "type": "string",
          "minLength": 1
        },
        "buildType": {
          "type": "string",
          "minLength": 1
        },
        "subjectNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "subjectDigests": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "algorithm", "digest"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "algorithm": {
                "type": "string",
                "minLength": 1
              },
              "digest": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
